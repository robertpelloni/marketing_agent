{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "skipLibCheck": true,
    "strict": false,
    "noEmitOnError": false,
    "declaration": true,
    "esModuleInterop": true
  },
  "include": ["src/**/*"]
}
