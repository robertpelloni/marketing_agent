{
  "name": "tormentnexus",
  "displayName": "TormentNexus — AI Control Plane",
  "version": "1.0.0",
  "publisher": "tormentnexus",
  "description": "Universal AI control plane: persistent memory, MCP tool routing, session import, enterprise RBAC. Works with every AI coding agent.",
  "categories": ["AI", "Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {"command": "tn.store", "title": "TN: Store Memory"},
      {"command": "tn.search", "title": "TN: Search Memory"},
      {"command": "tn.status", "title": "TN: System Status"}
    ],
    "keybindings": [
      {"command": "tn.search", "key": "ctrl+shift+m"},
      {"command": "tn.store", "key": "ctrl+shift+t"},
      {"command": "tn.status", "key": "ctrl+shift+p"}
    ],
    "configuration": {
      "title": "TormentNexus",
      "properties": {
        "tormentnexus.url": {"type": "string", "default": "http://127.0.0.1:7778", "description": "TN Kernel URL"}
      }
    }
  }
}
