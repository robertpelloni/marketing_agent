{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|new",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/session-start.bat"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.bat"
          }
        ]
      }
    ]
  }
}
