{
    "mcpServers": {
        "filesystem": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-filesystem",
                "./"
            ],
            "enabled": false,
            "env": {}
        },
        "git": {
            "command": "docker",
            "args": [
                "run",
                "-i",
                "--rm",
                "-v",
                "${PWD}:/git",
                "modelcontextprotocol/server-git"
            ],
            "enabled": false,
            "env": {}
        },
        "memora": {
            "command": "memora-server",
            "args": [],
            "enabled": false,
            "env": {
                "MEMORA_DB_PATH": "./data/memory/memora.db",
                "MEMORA_ALLOW_ANY_TAG": "1"
            }
        }
    }
}