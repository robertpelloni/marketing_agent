# =============================================================================
# tormentnexus Web App — Environment Variables
# Copy this file to .env.local and fill in your deployment values.
# All NEXT_PUBLIC_ vars are exposed to the browser runtime.
# =============================================================================

# --- tRPC / Core Backend ---
# URL for the tRPC HTTP endpoint served by packages/core.
# NEXT_PUBLIC_TRPC_URL=http://localhost:4000/trpc

# --- SSE Mesh Stream ---
# Base URL for the Server-Sent Events mesh stream (no trailing path).
# NEXT_PUBLIC_CORE_SSE_URL=http://localhost:3001

# --- WebSocket (Traffic Inspector) ---
# NEXT_PUBLIC_CORE_WS_URL=ws://localhost:7779

# --- Embedded Services ---
# mcpenetes infrastructure dashboard iframe URL.
# NEXT_PUBLIC_MCPENETES_URL=http://localhost:7779

# Open-WebUI instance URL.
# NEXT_PUBLIC_OPEN_WEBUI_URL=http://localhost:7778

# DeerFlow harness URL.
# NEXT_PUBLIC_DEER_FLOW_URL=http://localhost:2026

# tormentnexus Orchestrator dashboard / API base URL.
# Canonical variable:
# NEXT_PUBLIC_TORMENTNEXUS_ORCHESTRATOR_URL=http://localhost:3847
# Legacy compatibility variable:
# NEXT_PUBLIC_AUTOPILOT_URL=http://localhost:3847

# Jules dashboard URL.
# NEXT_PUBLIC_JULES_DASHBOARD_URL=http://localhost:3002/dashboard

# LMStudio Web UI URL (Director Diagnostics).
# NEXT_PUBLIC_LMSTUDIO_URL=http://localhost:1234
