func HandleGetIssue(ctx context.Context, args map[string]interface{}) (ToolResponse, error) {
	authToken, _ :=getString(args, "auth_token")
	orgSlug, _ :=getString(args, "organization_slug")
	projectSlug, _ :=getString(args, "project_slug")
	issueID, _ :=getString(args, "issue_id")
	if authToken == "" {
		return err("missing required argument: auth_token")
}

	if orgSlug == "" {
		return err("missing required argument: organization_slug")
}

	if projectSlug == "" {
		return err("missing required argument: project_slug")
}

	if issueID == "" {
		return err("missing required argument: issue_id")
}

	apiURL := fmt.Sprintf("https://sentry.io/api/0/organizations/%s/projects/%s/issues/%s/", orgSlug, projectSlug, issueID)
	req, reqErr := http.NewRequestWithContext(ctx, "GET", apiURL, nil)
	if reqErr != nil {
		return err(fmt.Sprintf("failed to create request: %s", reqErr.Error()))
}

	req.Header.Set("Authorization", "Bearer "+authToken)
	resp, fetchErr := sentryClient.Do(req)
	if fetchErr != nil {
		return err(fmt.Sprintf("failed to fetch issue: %s", fetchErr.Error()))
}

	defer resp.Body.Close()
	if resp.StatusCode != http.StatusOK {
		return err(fmt.Sprintf("Sentry API returned status %d: %s", resp.StatusCode, resp.Status))
}

	var issue map[string]interface{}
	parseErr := json.NewDecoder(resp.Body).Decode(&issue)
	if parseErr != nil {
		return err(fmt.Sprintf("failed to parse issue response: %s", parseErr.Error()))
}

	issueJSON, jsonErr := json.MarshalIndent(issue, "", "  ")
	if jsonErr != nil {
		return err(fmt.Sprintf("failed to format issue: %s", jsonErr.Error()))
}

	return ok(string(issueJSON))
}

func HandleListIssues(ctx context.Context, args map[string]interface{}) (ToolResponse, error) {
	authToken, _ :=getString(args, "auth_token")
	orgSlug, _ :=getString(args, "organization_slug")
	projectSlug, _ :=getString(args, "project_slug")
	query, _ :=getString(args, "query")
	limit, _ :=getInt(args, "limit")
	if limit <= 0 {
		limit = 10
	}
	if authToken == "" {
		return err("missing required argument: auth_token")
}

	if orgSlug == "" {
		return err("missing required argument: organization_slug")
}

	if projectSlug == "" {
		return err("missing required argument: project_slug")
}

	baseURL := fmt.Sprintf("https://sentry.io/api/0/organizations/%s/projects/%s/issues/", orgSlug, projectSlug)
	params := url.Values{}
	if query != "" {
		params.Set("query", query)

	params.Set("limit", strconv.Itoa(limit))
	fullURL := fmt.Sprintf("%s?%s", baseURL, params.Encode())
	req, reqErr := http.NewRequestWithContext(ctx, "GET", fullURL, nil)
	if reqErr != nil {
		return err(fmt.Sprintf("failed to create request: %s", reqErr.Error()))
}

	req.Header.Set("Authorization", "Bearer "+authToken)
	resp, fetchErr := sentryClient.Do(req)
	if fetchErr != nil {
		return err(fmt.Sprintf("failed to list issues: %s", fetchErr.Error()))
}

	defer resp.Body.Close()
	if resp.StatusCode != http.StatusOK {
		return err(fmt.Sprintf("Sentry API returned status %d: %s", resp.StatusCode, resp.Status))
}

	var issues []map[string]interface{}
	parseErr := json.NewDecoder(resp.Body).Decode(&issues)
	if parseErr != nil {
		return err(fmt.Sprintf("failed to parse issues list: %s", parseErr.Error()))
}

	var sb strings.Builder
	sb.WriteString(fmt.Sprintf("Found %d issues:\n\n", len(issues)))
	for i, issue := range issues {
		issueID, _ :=getString(issue, "id")
		title, _ :=getString(issue, "title")
		level, _ :=getString(issue, "level")
		sb.WriteString(fmt.Sprintf("%d. ID: %s, Title: %s, Level: %s\n", i+1, issueID, title, level))

	return ok(sb.String())
}

}
