{
  "name": "tormentnexus-monorepo",
  "version": "1.0.0-b1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "start": "node packages/cli/dist/cli/src/index.js start",
    "tormentnexus": "node packages/cli/dist/cli/src/index.js",
    "build": "node scripts/build_all.mjs",
    "build:workspace": "node scripts/build_all.mjs --workspace-only",
    "build:extensions": "node scripts/build_all.mjs --extensions-only",
    "dev": "node scripts/dev_tabby_ready.mjs",
    "dev:turbo": "set CI=true&& set TURBO_DAEMON=false&& turbo run dev --concurrency 22 --filter=!opencode-autopilot --filter=!@tormentnexus/cli --filter=!@opencode-autopilot/cli --filter=!@opencode-autopilot/server --filter=!@opencode-autopilot/shared --filter=!backend --filter=!frontend --filter=!@repo/*",
    "dev:server": "set TURBO_DAEMON=false&& turbo run dev:server --parallel --filter=!backend --filter=!frontend --filter=!@repo/*",
    "dev:web": "set TURBO_DAEMON=false&& turbo run dev --filter @tormentnexus/web",
    "lint": "pnpm run check:placeholders",
    "lint:turbo": "set TURBO_DAEMON=false&& turbo run lint --output-logs=errors-only",
    "test": "set TURBO_DAEMON=false&& turbo run test",
    "smoke:dashboard": "node scripts/dashboard-smoke.cjs",
    "check:placeholders": "node scripts/check-placeholder-regressions.mjs",
    "check:dev-readiness": "node scripts/verify_dev_readiness.mjs",
    "check:release-gate": "node scripts/check_release_gate.mjs",
    "check:release-gate:ci": "node scripts/check_release_gate.mjs --skip-readiness --with-turbo-lint",
    "index:sync": "node scripts/sync_master_index.mjs",
    "index:update": "node scripts/update_ingestion_status.mjs",
    "submodules:prune-orphans": "node scripts/prune_orphaned_gitlinks.mjs",
    "clean": "set TURBO_DAEMON=false&& turbo run clean",
    "typecheck": "set TURBO_DAEMON=false&& turbo run typecheck"
  },
